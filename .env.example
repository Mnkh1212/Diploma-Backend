DB_HOST=localhost
DB_PORT=5432
DB_USER=fintrack
DB_PASSWORD=fintrack123
DB_NAME=fintrack
JWT_SECRET=fintrack-secret-key-change-in-production
PORT=8080

# AI provider key (Gemini)
# AI_API_KEY, GEMINI_API_KEY, GOOGLE_API_KEY-ийн аль нэгийг ашиглаж болно.
# Үнэгүй key: https://aistudio.google.com/app/apikey
# ⚠️ ЭНЭ ФАЙЛД ЖИНХЭНЭ KEY БҮЙ ОРУУЛ — git-д commit хийгдвэл Google автоматаар revoke хийнэ.
AI_API_KEY=your-gemini-api-key-here
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Чөлөөт key-ийн project-аас хамаарч 2.0-flash дээр quota=0 байж болно.
# Эс бөгөөс gemini-2.5-flash, gemini-1.5-flash гэх мэтийг ашигла.
AI_MODEL=gemini-2.5-flash

# Social auth scaffold
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=
FACEBOOK_APP_ID=
APPLE_BUNDLE_ID=

# Python parser microservice (банкны хуулга парс хийдэг)
# Хоосон бол Go-н fallback parser ажиллана.
# Local docker-compose: http://parser:8000
PARSER_SERVICE_URL=http://parser:8000
